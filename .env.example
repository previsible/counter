# Required — get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# SQLite database path (relative to where you run the server)
DATABASE_URL=sqlite:///calories.db

# Optional — daily calorie target shown in summaries (default: 2000)
DAILY_CALORIE_TARGET=2000

# Timezone for display (default: Europe/London)
TIMEZONE=Europe/London
